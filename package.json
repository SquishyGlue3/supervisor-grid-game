{
  "name": "supervisor-ai-gridworld",
  "version": "1.0.0",
  "description": "Supervisor-AI Gridworld experiment for Prolific",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:http": "jest tests/http",
    "test:ws": "jest tests/websocket",
    "test:game": "jest tests/game",
    "test:coverage": "jest --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 15000,
    "forceExit": true,
    "testEnvironment": "node",
    "maxWorkers": 1
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "pg": "^8.13.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
